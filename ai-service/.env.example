# Application
APP_NAME=Sourcerra AI Service
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
PORT=8000

# OpenRouter / OpenAI
OPENAI_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_RETRIES=3
OPENROUTER_TIMEOUT=60

# Backend API (Node.js)
BACKEND_API_BASE_URL=http://localhost:3000/api
BACKEND_API_KEY=
BACKEND_API_TIMEOUT=30

# MCP Servers (comma-separated URLs)
MCP_SERVER_URLS=
MCP_CONNECTION_TIMEOUT=10
MCP_REQUEST_TIMEOUT=60

# Agents
AGENT_MAX_ITERATIONS=10
AGENT_DEFAULT_MODEL=
AGENT_ENABLE_HANDOFFS=true
AGENT_ENABLE_GUARDRAILS=true

# Storage
PROMPT_STORE_PATH=data/evaluation
EVALUATION_STORE_PATH=data/evaluation

# Database (optional, for production)
DATABASE_URL=

# Redis (optional, for production)
REDIS_URL=

# Security
API_KEY=
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sourcerra-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Feature Flags
PROMPT_VERSIONING_ENABLED=true
EVALUATION_ENABLED=true
TRACING_ENABLED=true
